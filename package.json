{
  "name": "ai-video-qa-playwright",
  "version": "1.0.0",
  "description": "Playwright + TypeScript test suite for AI video generation tools (Runway, Pika, Sora). Functional, UI, API, and exploratory tests with bug reports for AI Quality & Testing roles.",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:api": "playwright test tests/api/",
    "test:runway": "playwright test tests/runway/",
    "test:pika": "playwright test tests/pika/",
    "test:report": "playwright show-report",
    "test:debug": "playwright test --debug",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "type-check": "tsc --noEmit",
    "ci": "npm run type-check && npm run lint && npm test"
  },
  "keywords": [
    "playwright",
    "typescript",
    "qa",
    "automation",
    "ai-testing",
    "video-generation",
    "runway",
    "pika",
    "sora",
    "sdet"
  ],
  "author": "Afrin Ameer Khan",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.7.0",
    "@typescript-eslint/eslint-plugin": "^8.10.0",
    "@typescript-eslint/parser": "^8.10.0",
    "dotenv": "^16.4.5",
    "eslint": "^9.13.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.3"
  }
}
